{
    "name": "jeffersoncarvalho/laravel-datatables-oracle",
    "description": "jQuery DataTables API for Laravel",
    "keywords": [
        "yajra",
        "laravel",
        "dataTables",
        "jquery"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Arjay Angeles",
            "email": "aqangeles@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12",
        "illuminate/filesystem": "^12",
        "illuminate/http": "^12",
        "illuminate/support": "^12",
        "illuminate/view": "^12"
    },
    "autoload": {
        "psr-4": {
            "JeffersonCarvalho\\DataTables\\": "src/"
        },
        "files": [
            "src/helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonCarvalho\\DataTables\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "12.x-dev"
        },
        "laravel": {
            "providers": [
                "JeffersonCarvalho\\DataTables\\DataTablesServiceProvider"
            ],
            "aliases": {
                "DataTables": "JeffersonCarvalho\\DataTables\\Facades\\DataTables"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/yajra"
        }
    ]
}
